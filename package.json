{
  "name": "dev-controle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "docker:up": "docker compose up -d --build app",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:e2e": "docker compose --profile e2e run --rm e2e",
    "test": "vitest",
    "test:integration": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:docker": "docker build -f Dockerfile.e2e -t dev-controle-e2e . && docker run --rm --ipc=host dev-controle-e2e",
    "test:e2e:ui": "playwright test --ui",
    "type-check": "next typegen && tsc --noEmit",
    "start": "next start"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "6.19.3",
    "@prisma/extension-accelerate": "^3.0.1",
    "@sentry/nextjs": "^10.51.0",
    "axios": "^1.16.0",
    "dotenv": "^17.4.2",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-icons": "^5.6.0",
    "sonner": "^2.0.7",
    "yup": "^1.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
